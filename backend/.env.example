# core
API_PORT=51820
ENV=dev
LOG_LEVEL=DEBUG

# CORS — frontend dev origin
CORS_ORIGINS=http://localhost:51730

# Public-facing API origin used to construct magic-link URLs sent to users.
PUBLIC_API_BASE_URL=http://localhost:51820

# storage
DATABASE_URL=postgresql+asyncpg://myblog:myblog_dev@localhost:51832/myblog
REDIS_URL=redis://localhost:51833/0
DATA_DIR=./data
POSTS_DIR=./posts

# auth
JWT_SECRET=replace-with-32-bytes-of-randomness-for-prod
# 28800 = 8h (dev-friendly). Tighten in prod (e.g. 900 = 15min).
ACCESS_TOKEN_TTL=28800
# SECRETS_KEY is required (≥32 chars). Used as KDF input for AES-GCM encryption
# of TFA secrets stored in the database. Generate with: openssl rand -hex 32
SECRETS_KEY=replace-with-32-plus-bytes-of-randomness-for-prod
# Optional TTL/threshold overrides (defaults shown):
# REFRESH_TOKEN_TTL=2592000
# MAGIC_LINK_TTL=900
# TFA_CHALLENGE_TTL=300
# LOGIN_LOCKOUT_THRESHOLD=10
# LOGIN_LOCKOUT_WINDOW_SEC=900

# salts
LIKE_SALT=replace-with-random-32-bytes

# SMTP for outbound email (magic-link, comment notifications). Leave
# unset in dev — emails will log to stdout via structlog instead.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=secret
# SMTP_FROM=noreply@wangyang.dev
# SMTP_STARTTLS=true
# ADMIN_NOTIFY_EMAIL=admin@example.com
